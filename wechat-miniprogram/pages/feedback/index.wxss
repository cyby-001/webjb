.info-page {
  min-height: 100vh;
  padding: 24rpx 20rpx 40rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f3f6fb 100%);
}

.hero-card,
.info-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 28rpx;
  border: 1rpx solid #e8edf5;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.05);
}

.hero-card {
  padding: 26rpx 24rpx;
}

.hero-title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 800;
}

.hero-sub {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.7;
}

.info-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.feature-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(246,249,255,0.98));
}

.section-title {
  color: #1e293b;
  font-size: 28rpx;
  font-weight: 800;
}

.card-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.8;
}

.tip-item {
  margin-top: 16rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.8;
}

.feature-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.feature-tag {
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #4f46e5;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
}

.copy-btn {
  margin-top: 22rpx;
  height: 84rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #3b82f6, #4f46e5);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-btn.alt {
  background: linear-gradient(135deg, #0ea5e9, #2563eb);
}