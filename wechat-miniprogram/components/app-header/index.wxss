.hero {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-left: 20rpx;
  padding-right: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.hero-spacer {
  width: 100%;
}

.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.brand-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #3b82f6, #4f46e5);
  box-shadow: 0 10rpx 18rpx rgba(79, 70, 229, 0.24);
  position: relative;
  flex-shrink: 0;
}

.brand-body {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
  height: 20rpx;
  border: 3rpx solid #ffffff;
  border-radius: 6rpx;
}

.brand-handle {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 11rpx;
  height: 10rpx;
  border: 3rpx solid #ffffff;
  border-bottom: 0;
  border-radius: 8rpx 8rpx 0 0;
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.brand-sub {
  margin-top: 2rpx;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 600;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 0;
  flex-shrink: 0;
  margin-right: -30rpx;
}

.icon-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6ecf5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  box-shadow: 0 6rpx 14rpx rgba(15, 23, 42, 0.04);
}

.menu-btn.solo {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff, #f8fbff);
}

.menu-entry-image {
  width: 30rpx;
  height: 30rpx;
  display: block;
  opacity: 0.92;
}

.menu-mask {
  position: fixed;
  inset: 0;
  z-index: 120;
}

.menu-card {
  position: absolute;
  right: 20rpx;
  width: 296rpx;
  padding: 10rpx 0 12rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx;
  border: 1rpx solid #ebf0f7;
  box-shadow: 0 24rpx 44rpx rgba(15, 23, 42, 0.18);
  overflow: hidden;
}

.menu-group-title {
  padding: 10rpx 22rpx 8rpx;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 700;
}

.menu-divider {
  height: 1rpx;
  margin: 10rpx 18rpx;
  background: #edf2f7;
}

.menu-item {
  padding: 18rpx 22rpx;
  color: #334155;
  font-size: 26rpx;
  font-weight: 600;
}

.menu-item.strong {
  color: #059669;
}

.menu-item.danger {
  color: #ef4444;
}