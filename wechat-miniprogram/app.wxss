page {
  min-height: 100%;
  background: linear-gradient(180deg, #f8fbff 0%, #f2f6fb 36%, #edf2f8 100%);
  color: #1e293b;
  font-size: 28rpx;
}

view,
text,
picker,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  border: 0;
  background: transparent;
  line-height: 1.2;
  padding: 0;
}

button::after {
  border: none;
}

.container {
  min-height: 100vh;
  padding: 0 20rpx 152rpx;
}

.card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 28rpx;
  border: 1rpx solid #e9eef6;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.05);
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #1e293b;
}

.btn-primary {
  height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #3b82f6, #4f46e5);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-danger {
  height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-ghost {
  height: 64rpx;
  border-radius: 16rpx;
  background: #eef4ff;
  color: #3563eb;
  font-size: 25rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}